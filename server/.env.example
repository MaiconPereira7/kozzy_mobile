# Chave da API OpenRouter (obrigatória)
OPENROUTER_API_KEY=sua_chave_aqui

# Chave da API Gemini (opcional - usada como IA primária se configurada)
GEMINI_API_KEY=sua_chave_aqui

# Secret para assinar tokens JWT (troque em produção!)
JWT_SECRET=kozzy-secret-mude-em-producao

# URI do MongoDB Atlas (opcional - sem ela os dados ficam em memória)
MONGODB_URI=mongodb+srv://usuario:senha@cluster.mongodb.net/kozzy?appName=App-Kozzy

# Porta do servidor (padrão: 3000)
PORT=3000
